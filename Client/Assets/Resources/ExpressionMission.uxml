        <ui:VisualElement name="GaugeBarContainer" style="flex-grow: 0; flex-direction: row; justify-content: flex-start; width: 60%; height: 5%; align-self: auto; align-items: center; margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; display: flex; position: absolute; bottom: 130px; background-color: rgb(247, 240, 219); border-left-color: rgb(165, 173, 107); border-right-color: rgb(165, 173, 107); border-top-color: rgb(165, 173, 107); border-bottom-color: rgb(165, 173, 107); border-top-width: 10px; border-right-width: 10px; border-bottom-width: 10px; border-left-width: 10px; border-top-left-radius: 50px; border-top-right-radius: 50px; border-bottom-right-radius: 50px; border-bottom-left-radius: 50px; -unity-font: initial;">
