                </ui:VisualElement>
                <ui:VisualElement name="Row_Lower" style="flex-grow: 0; width: 100%; height: 50%; padding-top: 0; padding-right: 30px; padding-bottom: 0; padding-left: 30px; flex-direction: row; align-items: center; align-self: flex-start; justify-content: center;">
                    <ui:Button name="EmotionCard_2" text="평온함" class="button-expressionCard" style="border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;" />
